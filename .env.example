# ─────────────────────────────────────────────────────────────────────────────
# OziChat — Environment Variables
# Copy this file to .env and fill in every value before running docker compose.
#   cp .env.example .env
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_USERNAME=ozichat
DB_PASSWORD=StrongPassword123!

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=RedisStrongPass456!

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_LONG_BASE64_ENCODED_SECRET_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRY=900000        # 15 minutes in ms
JWT_REFRESH_EXPIRY=2592000000   # 30 days in ms

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=ozichat-media
AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_CDN_URL=                    # Optional: https://your-cloudfront-url.com
AWS_PRESIGNED_EXPIRY=15         # Minutes

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
FROM_EMAIL=noreply@ozichat.com
FROM_NAME=OziChat

# ── Firebase (optional — push notifications) ──────────────────────────────────
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=your-firebase-project-id
# Place firebase-service-account.json in the project root if FIREBASE_ENABLED=true

# ── WebRTC / TURN (optional — needed for calls behind strict NATs) ─────────────
TURN_URL=turn:your-turn-server.com:3478
TURN_USERNAME=ozichat
TURN_CREDENTIAL=TurnStrongPassword

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://api.ozichat.com
